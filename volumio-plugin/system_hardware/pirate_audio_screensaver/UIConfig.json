{
  "page": {
    "label": "Pirate Audio Screensaver"
  },
  "sections": [
    {
      "id": "settings",
      "element": "section",
      "label": "Settings",
      "icon": "fa-clock-o",
      "onSave": {
        "type": "controller",
        "endpoint": "saveSettings"
      },
      "content": [
        {
          "id": "idle_delay_seconds",
          "element": "input",
          "label": "Idle delay before screensaver starts",
          "doc": "Delay in seconds after playback stops.",
          "attributes": {
            "type": "number",
            "min": 10,
            "step": 1
          },
          "value": {
            "type": "number",
            "value": 300
          }
        },
        {
          "id": "font_size",
          "element": "input",
          "label": "Font size",
          "doc": "Clock font size in pixels.",
          "attributes": {
            "type": "number",
            "min": 20,
            "max": 120,
            "step": 1
          },
          "value": {
            "type": "number",
            "value": 58
          }
        },
        {
          "id": "display_rotation",
          "element": "select",
          "label": "Display rotation",
          "doc": "Rotation for the ST7789 display.",
          "options": [
            { "value": 0, "label": "0" },
            { "value": 90, "label": "90" },
            { "value": 180, "label": "180" },
            { "value": 270, "label": "270" }
          ],
          "value": {
            "type": "number",
            "value": 90
          }
        },
        {
          "id": "blank_turns_backlight_off",
          "element": "switch",
          "label": "Turn backlight off when blanked",
          "value": {
            "type": "boolean",
            "value": true
          }
        },
        {
          "id": "buttons_enabled",
          "element": "switch",
          "label": "Watch Pirate Audio buttons",
          "doc": "Keep disabled when another Pirate Audio plugin already handles the buttons.",
          "value": {
            "type": "boolean",
            "value": false
          }
        },
        {
          "id": "button_pins",
          "element": "input",
          "label": "Button GPIO pins",
          "doc": "Comma-separated BCM pin numbers.",
          "attributes": {
            "type": "text"
          },
          "value": {
            "type": "string",
            "value": "5,6,16,24"
          }
        },
        {
          "id": "log_level",
          "element": "select",
          "label": "Log level",
          "options": [
            { "value": "DEBUG", "label": "DEBUG" },
            { "value": "INFO", "label": "INFO" },
            { "value": "WARNING", "label": "WARNING" },
            { "value": "ERROR", "label": "ERROR" }
          ],
          "value": {
            "type": "string",
            "value": "INFO"
          }
        }
      ]
    }
  ]
}
