{
  "page": {
    "label": "Pirate Audio Screensaver"
  },
  "sections": [
    {
      "id": "settings",
      "element": "section",
      "label": "Settings",
      "icon": "fa-clock-o",
      "onSave": {
        "type": "controller",
        "endpoint": "saveSettings"
      },
      "content": [
        {
          "id": "idle_delay_seconds",
          "element": "input",
          "label": "Idle delay before screensaver starts",
          "doc": "Delay in seconds after playback stops. Default: 300 seconds.",
          "attributes": [
            { "type": "number" },
            { "min": 10 },
            { "step": 1 }
          ],
          "value": 300
        },
        {
          "id": "display_rotation",
          "element": "select",
          "label": "Display rotation",
          "doc": "Rotation for the ST7789 display. Default: 90.",
          "options": [
            { "value": 0, "label": "0" },
            { "value": 90, "label": "90" },
            { "value": 180, "label": "180" },
            { "value": 270, "label": "270" }
          ],
          "value": { "value": 90, "label": "90" }
        }
      ]
    }
  ]
}
